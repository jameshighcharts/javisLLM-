OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GSHEET_WEBAPP_URL=https://script.google.com/macros/s/REPLACE_ME/exec
GSHEET_WEBAPP_SECRET=replace_with_shared_secret
GSHEET_TAB_NAME=Sheet1
GSHEET_COMPETITOR_TAB_NAME=CompetitorMetrics

# Optional Supabase sync target
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SYNC=0

# Optional Salesforce CLI target org alias (for scripts/fetch_salesforce_soql.py)
# SF_TARGET_ORG=my-sandbox

# Benchmark options
OUR_TERMS=Highcharts
MODEL=gpt-4o-mini
# AUTO_MODELS=1 resolves config/benchmark/models.json before each scheduled run.
# Set AUTO_MODELS=0 to use MODEL/MODELS exactly as written below.
AUTO_MODELS=1
# Optional comma-separated override (takes priority over MODEL):
# MODELS=openai:gpt:latest,anthropic:opus:latest,anthropic:sonnet:latest,google:flash:latest,gpt-4o-mini,gpt-4o,gpt-5.2,claude-sonnet-4-5-20250929,claude-opus-4-5-20251101,gemini-2.5-flash
RUNS=3
WEB_SEARCH=1
BENCHMARK_CONFIG_PATH=./config/benchmark/config.json
BENCHMARK_MODEL_CATALOG_PATH=./config/benchmark/models.json

# Optional local-only Prompt Lab ChatGPT web scraper
# ENABLE_CHATGPT_WEB_SCRAPER=true
# CHATGPT_SESSION_COOKIE=name=value; other=value
# CHATGPT_WEB_HEADLESS=true
# CHATGPT_WEB_TIMEOUT_MS=90000
# CHATGPT_WEB_SLOW_MO_MS=0
