{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      "railway.json",
      "requirements.txt",
      "main.py",
      "llm_mention_benchmark.py",
      "apps/worker/**",
      "packages/py/benchmark_core/**",
      "scripts/trigger_benchmark_run.py"
    ]
  },
  "deploy": {
    "startCommand": "python -m worker.benchmark_worker",
    "restartPolicyType": "ALWAYS"
  }
}
